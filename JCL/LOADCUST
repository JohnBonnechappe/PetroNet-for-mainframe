//DELERR    DD DSN=Z63454.PETRONET.LOADERR,DISP=(MOD,DELETE,DELETE)
//DELMAP    DD DSN=Z63454.PETRONET.LOADMAP,DISP=(MOD,DELETE,DELETE)
