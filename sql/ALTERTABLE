--

ALTER TABLE Z63454.STK_TRANSN_TBL              
   ADD COLUMN   PROD_NO           CHAR(6)          
   ADD COLUMN   PACK_CODE         CHAR(4)               
   ADD COLUMN   TRANSN_TYPE_CODE  CHAR(1)               
   ADD COLUMN   STOCK_TRANSN_QTY  INTEGER     
   ADD COLUMN   REC_TMSTAMP       TIMESTAMP
   ;

ALTER TABLE Z63454.CUST_ACCT_TBL
    RENAME COLUMN AMT_OUTSTANDING TO  CUST_OUTSTANDING_DEBT
    ADD COLUMN
    ADD COLUMN REC_TMSTAMP       TIMESTAMP
   ;
