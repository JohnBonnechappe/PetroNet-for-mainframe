    ( LOCN_NO                  char(4)                         
    , PROD_NO                  char(6)
    , PACK_CODE                char(4)                        
    , ON_HAND_QTY              integer                              
    , ON_ORDER_QTY             integer                              
    , REC_TMSTAMP              timestamp                              
