  create table CUST_TBL                                    
     ( CUST_NO                    char(8) 
     , CUST_NAME                  char(25)
     , CUST_ADDR                  char(25)
     , CUST_PHONE                 char(15)
     , CUST_EMAIL                 char(25)
     , DELETED_FLAG               char(1)
     , REC_TMSTAMP                timestamp        
     ) IN DATABASE Z63454;  

    CREATE TABLE CUST_ACCT_TBL
     ( CUST_NO                    CHAR(8)
     , CUST_CURRENT_DEBT          decimal(9,2)
     , CUST_30_DAY_DEBT           decimal(9,2)
     , CUST_60_DAY_DEBT           decimal(9,2)
     , CUST_SETTLEMENT_DISCOUNT   decimal(9,2)
     , CUST_VOL_REBATE            decimal(9,2)
     , REC_TMSTAMP                timestamp 
    ) in database Z63454;   

    CREATE TABLE DEBTOR_TRANSN_TBL
    ( CUST_NO                     CHAR(8)
    , DEBTOR_TRANSN_TYPE_CODE     CHAR(1)
    , TRANSN_DATE                 timestamp
    , TRANSN_AMT                  decimal(9,2)
    , REC_TMSTAMP                 timestamp
    ) IN DATABASE Z63454;
--                                                      
  create table LOCN_TBL                                            
     ( LOCN_NO                   char(4)                              
     , LOCN_NAME                 char(25)                         
     , REC_TMSTAMP               timestamp                           
     ) IN DATABASE Z63454;                                    
--                                                        
  create table PROD_TBL                                       
     ( PROD_NO                   char(6)              
     , PROD_DESC                 char(25)
     , DELETED_FLAG              char(1)
     , REC_TMSTAMP               timestamp               
     ) IN DATABASE Z63454; 

create table PACK_TBL
     ) PACK_CODE                char(4)
     , PACK_DESC                char(25)
     , DELETED-FLAG             char(1)
     , REC_TMSTAMP              timestamp   
     ) IN DATABASE Z63454; 
                                        
--                                            
create table STOCK_HOLDING_TBL                       
    ( LOCN_NO                  char(4)                         
    , PROD_NO                  char(6)
    , PACK_CODE                char(4)                        
    , ON_HAND_QTY              integer                              
    , ON_ORDER_QTY             integer                              
    , REC_TMSTAMP              timestamp                              
    ) IN DATABASE Z63454;

    create table STOCK_TRANSN_TBL
    ( LOCN_NO                 Char(4)     
    , PROD_NO                 Char(6)
    , PACK_CODE               Char(4)
    , TRANSN_TYPE_CODE        Char(1)
    , STOCK_TRANSN_QTY        Integer
    , REC_TMSTAMP             timestamp   
    ) IN DATABASE Z63454
    ;


    create table RETAIL_TRANSN_TBL
    ( SEQ_NO                  smallint
    , SYS_NAME                char(10)
    , SITE_NAME               char(10)
    , TRANSN_DATE             char(08)
    , TRANSN_TIME             char(06)
    , TRANSN_TYPE_CODE        char(1)
    , TRANSN_PAYT_METHOD_CODE char(1)
    , TRASN_APPLIED_INDIC     char(1)
    , CUST_NO                 char(08)
    , SALE_ITEM               char(10)
    , SALE_QTY                smallint
    , SALE_PRICE              decimal(9,2)
    , SALE_TOTAL              decimal(9,2)
    , REC_TMSTAMP             timestamp
    ) IN DATABASE Z63454;                        
