    , STOCK_TRANSN_TYPE_CODE   Char(2)
    , TRANSN_DATE              Date
    , STOCK_TRANSN_QTY         Integer
    , REC_TMSTAMP              timestamp   
    ) IN DATABASE Z63454
    ;


    create table RETAIL_TRANSN_TBL
    ( SEQ_NO                  smallint
    , RETAIL_LOCN_NO          char(4)
    , SYS_NAME                char(10)
    , SITE_NAME               char(10)
    , TRANSN_DATE             char(08)
    , TRANSN_TIME             char(06)
