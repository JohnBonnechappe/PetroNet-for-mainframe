  create table CUST_TBL                                    
     ( CUST_NO                    char(8) 
     , CUST_NAME                  char(25)
     , CUST_ADDR                  char(25)
     , CUST_PHONE                 char(15)
     , CUST_EMAIL                 char(25)
     , GENERAL_REBATE_FLAG        char(1)
     , CASH_REBATE_FLAG           char(1)
     , VOLUME_REBATE_FLAG         char(1)
     , SETTLEMENT_DISCOUNT_FLAG   char(1)
     , DELETED_FLAG               char(1)
     , REC_TMSTAMP                timestamp        
     ) IN DATABASE Z63454;  

    CREATE TABLE CUST_ACCT_TBL
     ( CUST_NO                    CHAR(8)
     , CUST_CURRENT_DEBT          decimal(9,2)
     , CUST_30_DAY_DEBT           decimal(9,2)
     , CUST_60_DAY_DEBT           decimal(9,2)
     , REC_TMSTAMP                timestamp 
    ) in database Z63454; 

    CREATE TABLE CUST_REBATE_TBL
     ( CUST_NO                     CHAR(8) NOT NULL
     , REBATE_TYPE_CODE            char(2) NOT NULL
     , PROD_NO                     char(6) NOT NULL
     , REBATE_APPLIES_FROM         date
     , REBATE_APPLIES_TO           date
     , GENERAL_REBATE_PERCENT      decimal(9,2)
     , CASH_REBATE_PERCENT         decimal(9,2)
     , VOL_REBATE_PERCENT          decimal(9,2)
     , VOL_REBATE_VOLUME           smallint
     , SETTLEMENT_DISCOUNT_PERCENT decimal(9,2)
     , DELETED_FLAG                char(1)
     , REC_TMSTAMP                 timestamp 
    ) in database Z63454;

    CREATE TABLE DEBTOR_TRANSN_TBL
    ( CUST_NO                     CHAR(8)
    , DEBTOR_TRANSN_TYPE_CODE     CHAR(2)
    , TRANSN_DATE                 timestamp
    , TRANSN_AMT                  decimal(9,2)
    , REC_TMSTAMP                 timestamp
    ) IN DATABASE Z63454;
--                                                      
  create table LOCN_TBL                                            
     ( LOCN_NO                   char(4)                              
     , LOCN_NAME                 char(25)                         
     , REC_TMSTAMP               timestamp                           
     ) IN DATABASE Z63454;

  create table RETAIL_LOCN_TBL                                            
     ( RETAIL_LOCN_NO            char(4) 
     , LOCN_NO                   char(4)
     , RETAIL_LOCN_NAME          char(25)                         
     , REC_TMSTAMP               timestamp                           
     ) IN DATABASE Z63454;  
--                                                        
  create table PROD_TBL                                       
     ( PROD_NO                   char(6)              
     , PROD_DESC                 char(25)
     , DELETED_FLAG              char(1)
     , REC_TMSTAMP               timestamp               
     ) IN DATABASE Z63454; 

create table PACK_TBL
     ) PACK_CODE                char(4)
     , PACK_DESC                char(25)
     , DELETED-FLAG             char(1)
     , REC_TMSTAMP              timestamp   
     ) IN DATABASE Z63454; 
                                        
