    , TRANSN_PAYT_METHOD_CODE char(1)
    , TRASN_APPLIED_INDIC     char(1)
    , CUST_NO                 char(08)
    , PROD_NO                 char(6)
    , SALE_ITEM               char(10)
    , SALE_QTY                smallint
    , SALE_PRICE              decimal(9,2)
    , SALE_TOTAL              decimal(9,2)
    , TRANSN_PAYT_METHOD_CODE char(1)
    , TRANSN_APPLIED_INDIC    char(1)
    , REC_TMSTAMP             timestamp
    ) IN DATABASE Z63454;  

    create table RETAIL_SALES_DKT_TBL
    , LOCN_NO                 char(4)
    , SALE_ITEM               char(10)
    , TRANSN_DATE             date
    , SALE_TOTAL              decimal(9,2)
